# Turso Database Configuration
# Get these values from: turso db show reviews-db --url && turso db tokens create reviews-db

TURSO_DATABASE_URL="libsql://your-database-name.turso.io"
TURSO_AUTH_TOKEN="your-auth-token-here"

# Email (Resend) — contact/quote form notifications
# 1. Create an API key at https://resend.com/api-keys
# 2. RESEND_FROM must be a VERIFIED sender. Verify your domain at
#    https://resend.com/domains, then use e.g. "Pixelia <noreply@pixelia.co.il>".
#    Before the domain is verified you can test with "Pixelia <onboarding@resend.dev>"
#    (that test sender only delivers to the email of your own Resend account).
# 3. CONTACT_NOTIFICATION_EMAIL is where lead notifications are delivered.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="Pixelia <onboarding@resend.dev>"
CONTACT_NOTIFICATION_EMAIL="ilyaig8@gmail.com"

# AI Chatbot (Google Gemini) — powers /api/chat
# Get a key (free tier available) at https://aistudio.google.com/apikey
# Optional: GEMINI_MODEL (defaults to gemini-2.0-flash).
GEMINI_API_KEY="your-gemini-api-key"
# GEMINI_MODEL="gemini-2.0-flash"

# Google Analytics 4 — paste your Measurement ID to activate tracking.
# Get it at https://analytics.google.com (Admin → Data streams). Public by design.
# NOTE: NEXT_PUBLIC_* vars are baked at build time — redeploy after setting it.
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
